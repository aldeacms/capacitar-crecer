# Variables de entorno para Capacitar y Crecer
# Copia este archivo a .env.local para desarrollo o .env.production para producción

# ====================
# Supabase (Actual)
# ====================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ====================
# PocketBase (Migración)
# ====================
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=ChangeMe123!
# POCKETBASE_ADMIN_TOKEN=opcional-si-se-usa-token-estático

# ====================
# Email (Resend)
# ====================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL="Tu Nombre <no-reply@tudominio.cl>"

# ====================
# Aplicación
# ====================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====================
# Pasarelas de Pago
# ====================
# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_PUBLIC_KEY=your-mercadopago-public-key

# Flow
FLOW_API_KEY=your-flow-api-key
FLOW_SECRET_KEY=your-flow-secret-key

# Transbank
TBK_API_KEY=your-transbank-api-key
TBK_COMMERCE_CODE=your-commerce-code

# ====================
# VPS/Deploy (Opcional)
# ====================
# SSH_HOST=tu-vps-ip
# SSH_USER=usuario
# SSH_KEY_PATH=~/.ssh/id_rsa
# DOMAIN=tudominio.cl

# ====================
# Características
# ====================
# Deshabilitar Supabase durante migración (usar solo PocketBase)
# DISABLE_SUPABASE=false

# Modo dual (escribe en ambas bases durante migración)
# DUAL_WRITE_MODE=false

# ====================
# Debug
# ====================
# DEBUG=pocketbase*,supabase*
# LOG_LEVEL=info